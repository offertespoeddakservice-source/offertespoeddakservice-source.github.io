---
import Base from "../../layouts/Base.astro";
import { SITE, telHref, waHref } from "../../site.config.ts";
import { DIENSTEN } from "../../data/diensten.ts";
import { PLAATSEN, getPlaats } from "../../data/plaatsen.ts";
import { MATRIX } from "../../data/matrix.ts";
import DienstIcon from "../../components/DienstIcon.astro";

export function getStaticPaths() {
  return DIENSTEN.map((d) => ({ params: { dienst: d.slug }, props: { d } }));
}

const { d } = Astro.props;
const path = `/diensten/${d.slug}`;

const minPrice = d.vanafPrijs ? Number((d.vanafPrijs.match(/(\d+)/) || [])[1]) : null;
const serviceSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: d.titel,
  serviceType: d.titel,
  description: d.metaDescription,
  provider: { "@type": "RoofingContractor", name: SITE.bedrijfsnaam, telephone: `+${SITE.telefoonE164}` },
  areaServed: PLAATSEN.map((p) => ({ "@type": "City", name: p.naam })),
};
if (minPrice) serviceSchema.offers = { "@type": "Offer", priceSpecification: { "@type": "UnitPriceSpecification", priceCurrency: "EUR", minPrice } };
const faqSchema = d.faq.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: d.faq.map((f) => ({ "@type": "Question", name: f.v, acceptedAnswer: { "@type": "Answer", text: f.a } })),
    }
  : null;
const schema = faqSchema ? [serviceSchema, faqSchema] : serviceSchema;
const andere = DIENSTEN.filter((x) => x.slug !== d.slug);
const matrixVoorDienst = MATRIX.filter((c) => c.dienst === d.slug)
  .map((c) => getPlaats(c.plaats))
  .filter((p) => p);
const relArtikel = ({
  "goten-reinigen": { label: "Hoe vaak moet je goten reinigen?", href: "/kennisbank/hoe-vaak-dakgoot-reinigen" },
  "daklekkage": { label: "Daklekkage opsporen zonder sloopwerk", href: "/kennisbank/daklekkage-opsporen" },
  "dakreparatie": { label: "Wat kost daklekkage repareren?", href: "/kennisbank/wat-kost-daklekkage-repareren" },
  "platte-daken": { label: "Plat dak: repareren of vervangen?", href: "/kennisbank/plat-dak-vervangen-of-repareren" },
  "stormschade": { label: "Stormschade: eerste hulp", href: "/kennisbank/stormschade-eerste-hulp" },
  "dakcoating": { label: "Wat kost dak coaten?", href: "/kennisbank/wat-kost-dak-coaten" },
  "dak-reinigen": { label: "Mos op je dak verwijderen", href: "/kennisbank/mos-op-dak-verwijderen" },
  "dakpannen-vervangen": { label: "Dakpannen coaten of vervangen?", href: "/kennisbank/dakpannen-coaten-of-vervangen" },
  "dakgoot-vervangen": { label: "Verstopte regenpijp of lekkende dakgoot", href: "/kennisbank/verstopte-regenpijp-lekkende-dakgoot" },
  "schoorsteen-vegen": { label: "Hoe vaak schoorsteen vegen?", href: "/kennisbank/schoorsteen-vegen-hoe-vaak" },
  "zonnepanelen-reinigen": { label: "Zonnepanelen reinigen: is het nodig?", href: "/kennisbank/zonnepanelen-reinigen-nodig" },
} as Record<string, { label: string; href: string }>)[d.slug];
---

<Base title={d.metaTitle} description={d.metaDescription} path={path} schema={schema}>
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow" style="color:#ffb486;">{d.titel} · {SITE.regioOmschrijving}</p>
      <h1>{d.h1}</h1>
      <p class="lead">{d.intro}</p>
      <div class="btn-row" style="margin-top:22px;">
        <a class="btn btn--primary" href={telHref}>Bel {SITE.telefoonWeergave}</a>
        <a class="btn btn--wa" href={waHref(`Hoi Rens, ik heb een vraag over ${d.titel.toLowerCase()}.`)}>WhatsApp Rens</a>
      </div>
      <img src={d.afbeelding ?? `/img/${d.slug}.jpg`} alt={`${d.titel} in de regio Den Bosch — Spoed Dak Service`} loading="lazy" width="900" height="600" style="margin-top:28px;border-radius:12px;width:100%;max-width:820px;height:auto;display:block;" />
    </div>
  </section>

  <section class="section">
    <div class="wrap" style="display:grid; grid-template-columns: 1.3fr .9fr; gap:40px;">
      <div class="prose">
        <h2>Wat ik voor je doe</h2>
        <ul class="checks">
          {d.punten.map((p) => <li>{p}</li>)}
        </ul>
        <p>
          Werk je liever met één vast aanspreekpunt voor je hele dak? Dat is precies wat ik bied:
          ik kom langs, leg uit wat ik zie, en je krijgt een vaste prijs vooraf. Geen callcenter,
          geen verrassingen.
        </p>
        {relArtikel && (
          <p style="margin-top:18px;"><strong>Meer weten?</strong> Lees: <a href={relArtikel.href}>{relArtikel.label}</a></p>
        )}
      </div>
      <aside>
        <div class="card">
          <h3>Direct contact</h3>
          <p>Bel of WhatsApp voor een gratis, vrijblijvende inspectie in {SITE.regioOmschrijving}.</p>
          <div class="btn-row" style="margin-top:14px; flex-direction:column;">
            <a class="btn btn--primary" href={telHref}>{SITE.telefoonWeergave}</a>
            <a class="btn btn--outline" href="/contact">Offerte aanvragen</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  {d.faq.length > 0 && (
    <section class="section section--soft">
      <div class="wrap">
        <h2>Veelgestelde vragen over {d.titel.toLowerCase()}</h2>
        <div class="faq" style="margin-top:16px; max-width:760px;">
          {d.faq.map((f) => (
            <details>
              <summary>{f.v}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section section--white">
    <div class="wrap">
      <h2>{d.titel} in de regio Den Bosch</h2>
      {matrixVoorDienst.length > 0 && (
        <>
          <p class="lead">Direct naar {d.titel.toLowerCase()} in jouw plaats:</p>
          <div class="chips" style="margin-bottom:18px;">
            {matrixVoorDienst.map((p) => <a class="chip" href={`/werkgebied/${p.slug}/${d.slug}`}>{d.titel} in {p.naam}</a>)}
          </div>
        </>
      )}
      <p class="lead">Heel mijn werkgebied — kies je plaats:</p>
      <div class="chips">
        {PLAATSEN.map((p) => <a class="chip" href={`/werkgebied/${p.slug}`}>{p.naam}</a>)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Andere diensten</h2>
      <div class="grid grid-3" style="margin-top:18px;">
        {andere.map((x) => (
          <a class="card" href={`/diensten/${x.slug}`}>
            <DienstIcon slug={x.slug} />
            <h3>{x.titel}</h3>
            <p>{x.kort}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
