---
import Base from "../layouts/Base.astro";
import { SITE, telHref, waHref } from "../site.config.ts";
import { DIENSTEN } from "../data/diensten.ts";
import { PLAATSEN } from "../data/plaatsen.ts";
import DienstIcon from "../components/DienstIcon.astro";
import { ARTIKELEN } from "../data/artikelen.ts";

const score = SITE.reviews.score.toString().replace(".", ",");
const googleReviewLink = SITE.reviewLink && !SITE.reviewLink.includes("JOUW_PLACE_ID") ? SITE.reviewLink : null;

const faq = [
  { v: "Wat kost het om iemand te laten komen?", a: "Wil je weten hoe je dak ervoor staat? Dat doe ik via de Dak-APK: binnen een dagdeel een compleet keuringsrapport met foto's, voor €49. Weet je al wat er moet gebeuren — bijvoorbeeld goten reinigen? Dan hoor je gewoon de vaste prijs vooraf." },
  { v: "Hoe snel kun je komen?", a: "Bij spoed en lekkage vaak nog dezelfde dag in de regio Den Bosch. Bel of WhatsApp me, dan hoor je meteen wat kan." },
  { v: "Werk je ook bij mij in de buurt?", a: `Ik werk in ${SITE.regioOmschrijving}. Staat je plaats er niet bij? Bel gerust, vaak kan ik er toch bij.` },
  { v: "Krijg ik garantie?", a: "Ja, op het uitgevoerde werk krijg je garantie. Ik leg vooraf duidelijk uit wat ik doe en wat het kost." },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({ "@type": "Question", name: f.v, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
---

<Base
  title={`Dakdekker regio Den Bosch | ${SITE.bedrijfsnaam}`}
  description="Vakkundig dakwerk door één vaste man in de regio Den Bosch. Dak-APK voor €49, daklekkage vaak dezelfde dag, eerlijke prijs vooraf."
  path="/"
  schema={faqSchema}
>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="topline">
        <span class="kicker">Dakdekker · {SITE.regioOmschrijving}</span>
        <span class="stars"><span class="ster">★★★★★</span> <b>{score}</b></span>
      </div>
      <h1>Vakkundig dakwerk<br />door één vaste man</h1>
      <p class="lead">
        Geen callcenter, geen verrassingen achteraf. Je krijgt mij — Rens — aan de lijn,
        ik kom langs, en je hoort eerlijk wat er nodig is. Vaste prijs vooraf.
      </p>
      <div class="pricehook">
        <span class="van">Dak-APK<br />keuring</span>
        <span class="big">€49</span>
        <span class="per">compleet fotorapport<br />binnen een dagdeel</span>
      </div>
      <div class="hero-checks">
        <span><span class="v">✓</span> Eerlijk advies, geen verkooppraatje</span>
        <span><span class="v">✓</span> Vaste prijs, geen verrassingen</span>
        <span><span class="v">✓</span> Garantie op het werk</span>
        <span><span class="v">✓</span> Vaak dezelfde dag bij spoed</span>
      </div>
      <div class="btn-row">
        <a class="btn btn--primary" href={telHref}>Bel {SITE.telefoonWeergave}</a>
        <a class="btn btn--wa" href={waHref()}>WhatsApp Rens</a>
        <a class="btn btn--ghost" href="/dak-apk">Bekijk de Dak-APK</a>
      </div>
    </div>
  </section>

  <!-- DIENSTEN -->
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Wat ik doe</p>
      <h2>Voor je hele dak één aanspreekpunt</h2>
      <p class="lead">Van een verstopte goot tot een lekkend dak — snel, netjes, en met een eerlijke prijs vooraf.</p>
      <div class="grid grid-3" style="margin-top:26px;">
        {DIENSTEN.map((d, i) => (
          <a class="card" href={`/diensten/${d.slug}`}>
            <DienstIcon slug={d.slug} />
            <h3 style="margin-top:6px;">{d.titel}</h3>
            <p>{d.kort}</p>
            {d.vanafPrijs && <span class="price">{d.vanafPrijs}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WAAROM RENS -->
  <section class="section section--white">
    <div class="wrap">
      <p class="eyebrow">Waarom mij</p>
      <h2>Een echte dakdekker, geen tussenpersoon</h2>
      <div class="grid grid-3" style="margin-top:22px;">
        <div class="card">
          <h3>Je krijgt mij</h3>
          <p>Eén vast gezicht van offerte tot oplevering. Korte lijnen — gewoon mijn nummer, geen callcenter.</p>
        </div>
        <div class="card">
          <h3>Eerlijke prijs vooraf</h3>
          <p>Vaste prijs voordat ik aan een klus begin, geen verrassingen achteraf. Wil je eerst weten hoe je dak ervoor staat? Dat kan via de Dak-APK, voor €49.</p>
        </div>
        <div class="card">
          <h3>Uit de regio</h3>
          <p>Ik werk in {SITE.regioOmschrijving} — vaak ben ik al bij jou in de buurt.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ZIE HET VERSCHIL (vóór/na) -->
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Zie het verschil</p>
      <h2>Voor &amp; na — goten reinigen</h2>
      <p class="lead">Volle, dichtgeslibde goten lopen over en geven vocht. Zo zien ze eruit vóór en ná.</p>
      <div class="grid grid-2" style="margin-top:24px;">
        <figure style="margin:0;position:relative;">
          <img src="/img/goot-vol.jpg" alt="Volle dakgoot met blad en mos vóór reiniging" loading="lazy" width="900" height="700" style="width:100%;height:auto;border-radius:12px;display:block;" />
          <figcaption style="position:absolute;top:12px;left:12px;background:var(--navy);color:#fff;font-family:var(--font-display);font-weight:800;padding:5px 12px;border-radius:6px;font-size:.85rem;">VOOR</figcaption>
        </figure>
        <figure style="margin:0;position:relative;">
          <img src="/img/goot-schoon.jpg" alt="Schone, leeggemaakte dakgoot na reiniging" loading="lazy" width="900" height="700" style="width:100%;height:auto;border-radius:12px;display:block;" />
          <figcaption style="position:absolute;top:12px;left:12px;background:var(--ok);color:#fff;font-family:var(--font-display);font-weight:800;padding:5px 12px;border-radius:6px;font-size:.85rem;">NA</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- WIJK-PLANNER (urgentie, zoals flyer) -->
  <section class="section">
    <div class="wrap" style="display:grid; grid-template-columns: 1.1fr .9fr; gap:34px; align-items:center;">
      <div>
        <p class="eyebrow">Plan slim</p>
        <h2>Ik ben binnenkort bij jou in de wijk</h2>
        <p class="lead">Plan je klus als ik tóch in de buurt ben, dan is dat voor jou het handigst gepland. Bel of app even — dan zeg ik wanneer ik in jouw straat zit.</p>
        <div class="btn-row" style="margin-top:18px;">
          <a class="btn btn--primary" href={telHref}>Bel {SITE.telefoonWeergave}</a>
          <a class="btn btn--outline" href="/werkgebied">Bekijk werkgebied</a>
        </div>
      </div>
      <div class="planner">
        <strong style="font-family:var(--font-display); color:var(--navy); text-transform:uppercase; letter-spacing:.03em; font-size:.92rem;">Wanneer ben ik in jouw wijk?</strong>
        <div class="days">
          <div class="day">MA</div><div class="day">DI</div><div class="day">WO</div><div class="day">DO</div><div class="day">VR</div><div class="day">ZA</div>
        </div>
        <p style="margin:0; color:var(--muted); font-size:.95rem;">Datum al geweest? Bel toch — vaak ben ik snel weer in de buurt.</p>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF / REVIEWS -->
  <section class="section section--navy" style="text-align:center;">
    <div class="wrap">
      <p class="eyebrow" style="color:#ffb486;">Wat klanten zeggen</p>
      <div class="stars" style="justify-content:center; margin-bottom:6px;">
        <span class="ster" style="font-size:1.6rem;">★★★★★</span> <b style="font-size:1.9rem;">{score}</b>
      </div>
      <h2>Mensen kiezen voor een échte vakman uit de buurt</h2>
      <p class="lead" style="margin:0 auto 22px; color:#c2d2e3;">
        Geen callcenter, wél iemand die terugbelt en eerlijk zegt wat nodig is. Tevreden na de klus?
        Een korte Google-review helpt mij enorm — én helpt je buren een betrouwbare dakdekker te vinden.
      </p>
      {googleReviewLink && <a class="btn btn--primary" href={googleReviewLink}>Bekijk &amp; plaats reviews op Google</a>}
    </div>
  </section>

  <!-- ZO WERKT HET -->
  <section class="section section--white">
    <div class="wrap">
      <p class="eyebrow">Zo werkt het</p>
      <h2>Van belletje tot klaar dak — in 4 stappen</h2>
      <div class="stappen">
        <div class="stap"><div class="n">1</div><h3>Bel of app</h3><p>Je krijgt mij direct aan de lijn. Vertel kort wat er speelt.</p></div>
        <div class="stap"><div class="n">2</div><h3>Dak-APK of meteen aan de slag</h3><p>Twijfel je? Ik kom langs met de Dak-APK (€49) en je krijgt een compleet rapport. Weet je het al? Dan spreken we gelijk de vaste prijs af.</p></div>
        <div class="stap"><div class="n">3</div><h3>Vaste prijs vooraf</h3><p>Je hoort de prijs vóór ik begin. Geen voorrijkosten, geen verrassingen.</p></div>
        <div class="stap"><div class="n">4</div><h3>Netjes gedaan</h3><p>Ik voer het werk uit, ruim op en geef garantie op wat ik doe.</p></div>
      </div>
    </div>
  </section>

  <!-- WERKGEBIED -->
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Werkgebied</p>
      <h2>In welke plaatsen ik kom</h2>
      <p class="lead">Klik op je plaats voor meer info — of bel gerust als je plaats er niet bij staat.</p>
      <div class="chips">
        {PLAATSEN.map((p) => <a class="chip" href={`/werkgebied/${p.slug}`}>{p.naam}</a>)}
        <a class="chip" href="/werkgebied">Hele werkgebied →</a>
      </div>
    </div>
  </section>

  <!-- KENNISBANK -->
  <section class="section section--white">
    <div class="wrap">
      <p class="eyebrow">Kennisbank</p>
      <h2>Daktips & eerlijke uitleg</h2>
      <p class="lead">Zo weet je wat er speelt voordat je belt — zonder verkooppraatje.</p>
      <div class="grid grid-3" style="margin-top:22px;">
        {ARTIKELEN.map((a) => (
          <a class="card" href={`/kennisbank/${a.slug}`}>
            <h3>{a.titel}</h3>
            <p>{a.metaDescription}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Veelgestelde vragen</p>
      <h2>Goed om te weten</h2>
      <div class="faq" style="margin-top:18px; max-width:780px;">
        {faq.map((f) => (
          <details>
            <summary>{f.v}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Base>
