---
import Base from "../layouts/Base.astro";
import { SITE, telHref, waHref } from "../site.config.ts";

const prijstabel = [
  { dienst: "Dakvervanging / renovatie", prijs: "€50–285 p/m² · doorgaans €1.500–3.000+", uitleg: "Materiaalafhankelijk (bitumen goedkoopst, leien duurst). Altijd vooraf een vaste prijs." },
  { dienst: "Lekdetectie", prijs: "€300–500", uitleg: "Eén lek opsporen en dichten, inclusief materiaal." },
  { dienst: "Kleine reparatie", prijs: "€130–250", uitleg: "Losse pannen, nokvorst, klein herstel." },
  { dienst: "Dakgoot reinigen", prijs: "€75–225", uitleg: "Afhankelijk van lengte en bereikbaarheid." },
  { dienst: "Dak ontmossen", prijs: "€9–15 per m²", uitleg: "Plus coating €30–45 per m², indien gewenst." },
];

const bezwaren = [
  {
    v: "Ik ken dit bedrijf niet — hoe weet ik dat dit geen oplichterij is?",
    a: "Terechte vraag in een branche waar dat voorkomt. Ik werk onder mijn eigen naam, met mijn eigen 06-nummer — je krijgt mij aan de lijn, geen callcenter. Wat ik beloof, staat hieronder zwart op wit, inclusief wat er gebeurt als ik het een keer niet waarmaak.",
  },
  {
    v: "€49 is verdacht goedkoop — is dit een lokkertje voor dure meerwerk-druk?",
    a: "De Dak-APK kost mij zelf meer dan €49 om uit te voeren — het is bewust een instapprijs, geen verdienmodel. Zie je aanleiding voor vervolgwerk, dan hoor je de prijs uit de tabel hieronder, die al openbaar staat vóórdat je ook maar aanvraagt. Geen verrassingsfactuur achteraf.",
  },
  {
    v: "Wat als jullie de reactietijd-garantie zelf een keer niet halen?",
    a: "Bij normale drukte: dan is de Dak-APK gratis. Bij een officiële weerswaarschuwing (storm/code oranje-rood) kan de reactietijd oplopen — maar dan hoor je altijd binnen 24 uur waar je aan toe bent. Dat zeggen we liever vooraf dan dat je er als enige achter komt.",
  },
  {
    v: "Ik heb weleens een dakdekker gebeld die niet reageerde of kwam opdagen — waarom zou dit anders zijn?",
    a: "Vraag vóór 12:00 aan: je hoort dezelfde middag van me. Na 12:00: uiterlijk de volgende ochtend vóór 12:00. Geen vaag \"we bellen snel terug\" — een concreet moment, met een concrete consequentie als ik het mis.",
  },
  {
    v: "Waarom niet gewoon via een offerteplatform, dan vergelijk ik meteen meerdere aanbieders?",
    a: "Mag natuurlijk. Het verschil: bij mij ligt de prijstabel al open vóórdat je iets aanvraagt — het vergelijken heb je dan eigenlijk al gehad. Geen wachten op meerdere offertes, geen gokken wat een eerlijke prijs is.",
  },
  {
    v: "Is een inspectie voor €49 wel grondig, of een truc om binnen te komen waarna toch aangedrongen wordt op een dure klus?",
    a: "Na de Dak-APK krijg je een eerlijk rapport en, als er iets nodig is, een prijs uit de vaste tabel — geen verkooppraatje, geen druk. Niks nodig? Dan hoor je dat ook gewoon.",
  },
  {
    v: "Kan ik dit niet gewoon zelf checken, of via de buurman?",
    a: "Voor een deel wel — maar een dak op hoogte goed beoordelen zonder er zelf op te klimmen, dát is precies waar de Dak-APK voor is. Wat je vanaf de grond ziet, is zelden het hele verhaal.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: bezwaren.map((f) => ({ "@type": "Question", name: f.v, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};

const keuringOnderdelen = [
  { titel: "Dakbedekking / pannen", uitleg: "Staat + foto van de hele bedekking." },
  { titel: "Nokvorsten", uitleg: "Los of vast — vaak het eerste dat begeeft." },
  { titel: "Dakgoot", uitleg: "Verstopping en staat, incl. afwatering." },
  { titel: "Mos & aanslag", uitleg: "Hoeveel, en of het risico geeft op vocht." },
  { titel: "Loodwerk & aansluitingen", uitleg: "Vaak de eerste plek waar het misgaat." },
  { titel: "Vochtplekken / lekkage-indicaties", uitleg: "Zichtbare sporen, ook als er nog geen lek is." },
  { titel: "Zonnepanelen (indien aanwezig)", uitleg: "Conditie en bevestiging, als extra check." },
];
---

<Base
  title={`Dak-APK voor €49 — compleet keuringsrapport binnen een dagdeel | ${SITE.bedrijfsnaam}`}
  description="De Dak-APK: binnen een dagdeel weet je zwart op wit of je dak nog goed is, met foto's van elke risicoplek. Voor €49, zonder verplichtingen achteraf."
  path="/dak-apk"
  schema={faqSchema}
>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="topline">
        <span class="kicker">Dak-APK · {SITE.regioOmschrijving}</span>
      </div>
      <h1>Binnen een dagdeel weet je<br />zwart op wit hoe je dak ervoor staat</h1>
      <p class="lead">
        Met foto's van elke risicoplek, voor €49, zonder verplichtingen achteraf. Geen gok, geen vaag praatje —
        een compleet keuringsrapport, net zo concreet als een APK voor je auto.
      </p>
      <div class="pricehook">
        <span class="van">Dak-APK<br />voor</span>
        <span class="big">€49</span>
        <span class="per">compleet rapport<br />binnen een dagdeel</span>
      </div>
      <div class="hero-checks">
        <span><span class="v">✓</span> 6-7 punten gecontroleerd, met foto</span>
        <span><span class="v">✓</span> Reactie dezelfde middag of volgende ochtend</span>
        <span><span class="v">✓</span> Niet tevreden? Geld terug, geen vragen</span>
      </div>
      <div class="btn-row">
        <a class="btn btn--primary" href="#aanvragen">Vraag de Dak-APK aan</a>
        <a class="btn btn--wa" href={waHref("Hoi Rens, ik wil de Dak-APK aanvragen.")}>WhatsApp Rens</a>
      </div>
    </div>
  </section>

  <!-- WAT JE KRIJGT -->
  <section class="section section--white">
    <div class="wrap">
      <p class="eyebrow">Wat je krijgt</p>
      <h2>Eén compleet keuringsrapport, geen half werk</h2>
      <p class="lead">Ik loop elk onderdeel na, ook als het gewoon goed is — juist dan is dat zelf het bewijs.</p>
      <div class="grid grid-3" style="margin-top:22px;">
        {keuringOnderdelen.map((k) => (
          <div class="card">
            <h3>{k.titel}</h3>
            <p>{k.uitleg}</p>
          </div>
        ))}
      </div>
      <div class="grid grid-2" style="margin-top:16px;">
        <div class="card">
          <h3>Toelichting per risicoplek</h3>
          <p>Bij elke gevonden aandachtsplek een korte, geschreven uitleg in gewone taal — geen jargon, geen "professionele dakinspectie"-praat.</p>
        </div>
        <div class="card">
          <h3>Eenvoudig onderhoudsadvies</h3>
          <p>Een inschatting wat er de komende twee jaar aan zit te komen, met een globale kostenrichting — zodat je niet voor verrassingen komt te staan.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GARANTIE -->
  <section class="section section--navy">
    <div class="wrap">
      <p class="eyebrow" style="color:#ffb486;">De garantie</p>
      <h2>Twee beloftes, allebei met een echte consequentie</h2>
      <div class="grid grid-2" style="margin-top:22px;">
        <div class="card" style="background:#fff;">
          <h3>Reactietijd-garantie</h3>
          <p>Vraag je vóór 12:00 aan? Dan hoor je dezelfde middag van me. Na 12:00? Uiterlijk de volgende ochtend vóór 12:00. Lukt me dat niet, dan is je Dak-APK gratis.</p>
        </div>
        <div class="card" style="background:#fff;">
          <h3>Rapport-tevredenheidsgarantie</h3>
          <p>Vind je het rapport na afloop, om welke reden dan ook, de €49 niet waard? Dan krijg je het terug. Geen vragen.</p>
        </div>
      </div>
      <p class="lead" style="margin-top:20px; color:#c2d2e3;">
        Bij een officiële weerswaarschuwing (storm, code oranje/rood) kan de reactietijd oplopen — het is dan druk bij iedereen.
        Maar ook dan hoor je altijd binnen 24 uur waar je aan toe bent. Dat zeggen we liever vooraf dan dat je er zelf achter komt.
      </p>
    </div>
  </section>

  <!-- PRIJSTABEL VERVOLGKLUSSEN -->
  <section class="section">
    <div class="wrap" style="max-width:860px;">
      <p class="eyebrow">Als er iets moet gebeuren</p>
      <h2>Vooraf al een eerlijke prijsindicatie</h2>
      <p class="lead">Blijkt er tijdens de Dak-APK iets nodig? Dan ken je de bandbreedte al, ruim vóórdat je iets besluit.</p>
      <table class="ptable" style="margin-top:20px;">
        <thead>
          <tr><th>Klus</th><th>Richtprijs</th><th>Toelichting</th></tr>
        </thead>
        <tbody>
          {prijstabel.map((r) => (
            <tr>
              <td style="font-weight:700; color:var(--navy);">{r.dienst}</td>
              <td class="prijs">{r.prijs}</td>
              <td style="color:var(--muted);">{r.uitleg}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="notice" style="margin-top:18px;">
        Richtprijzen op basis van gangbare klussen in de regio. De uiteindelijke prijs hangt af van de situatie ter plaatse —
        bij een dreigende overschrijding van meer dan 10% laat ik dat vooraf weten, zoals de wet ook voorschrijft. Loopt het toch
        anders, dan hoor je dat vooraf via een appje met het bedrag — nooit een verrassing achteraf.
      </p>
    </div>
  </section>

  <!-- EERLIJKE PLANNING (geen nep-schaarste) -->
  <section class="section section--soft">
    <div class="wrap" style="max-width:760px;">
      <p class="eyebrow">Even eerlijk</p>
      <h2>Ik werk alleen, dus mijn agenda is echt beperkt</h2>
      <p class="lead">
        Geen kunstmatige aftelklok — gewoon de realiteit van een solo-vakman. Zit je midden in een storm of een acute lekkage?
        Dan gaat de reactietijd-garantie hierboven voor: ik reageer, ook als het druk is. Wil je juist rustig laten checken
        of je dak nog goed is? Vraag gerust ruim vooraf aan, dan plannen we een moment dat past.
      </p>
    </div>
  </section>

  <!-- BEZWAREN / FAQ -->
  <section class="section section--white">
    <div class="wrap">
      <p class="eyebrow">Voordat je aanvraagt</p>
      <h2>Wat mensen mij vaak vragen</h2>
      <div class="faq" style="margin-top:18px; max-width:820px;">
        {bezwaren.map((f) => (
          <details>
            <summary>{f.v}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- AANVRAAGFORMULIER -->
  <section class="section section--navy" id="aanvragen">
    <div class="wrap split">
      <div>
        <p class="eyebrow" style="color:#ffb486;">Aanvragen</p>
        <h2>Dak-APK aanvragen — €49</h2>
        <p class="lead" style="color:#c2d2e3;">Vul kort in wat er speelt, dan hoor je van me binnen de reactietijd hierboven.</p>
        <form class="form" method="POST" action="mailto:offerte.spoeddakservice@gmail.com" enctype="text/plain" style="margin-top:20px; background:#fff; padding:22px; border-radius:12px;">
          <input type="hidden" name="bron" value="dak-apk-pagina" />
          <label>Naam
            <input type="text" name="naam" required autocomplete="name" />
          </label>
          <label>Telefoon
            <input type="tel" name="telefoon" required autocomplete="tel" />
          </label>
          <label>E-mail (optioneel)
            <input type="email" name="email" autocomplete="email" />
          </label>
          <label>Plaats
            <input type="text" name="plaats" autocomplete="address-level2" />
          </label>
          <label>Is er nu al een zichtbaar probleem, of wil je het laten checken?
            <select name="aanleiding">
              <option value="incident">Er is nu al schade/een lek — ik wil snel iemand</option>
              <option value="preventie">Geen acuut probleem — ik wil het gewoon laten checken</option>
            </select>
          </label>
          <label>Korte omschrijving (optioneel)
            <textarea name="beschrijving" placeholder="Bijv. mos op het dak, of een vochtplek op zolder"></textarea>
          </label>
          <button class="btn btn--primary" type="submit">Vraag de Dak-APK aan</button>
          <p class="notice">Je gegevens gebruik ik alleen om deze aanvraag op te pakken — nooit voor iets anders. Liever direct? Bel of WhatsApp, dan heb je meteen antwoord.</p>
        </form>
      </div>
      <aside>
        <div class="card" style="background:#fff;">
          <h3>Direct contact</h3>
          <ul class="checks" style="margin-top:8px;">
            <li><a href={telHref}>{SITE.telefoonWeergave}</a></li>
            <li><a href={waHref("Hoi Rens, ik wil de Dak-APK aanvragen.")}>WhatsApp Rens</a></li>
            <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
          </ul>
          <p style="margin-top:10px; color:var(--muted);">Werkgebied: {SITE.regioOmschrijving}.</p>
          <p style="margin-top:6px; color:var(--muted);">Ma–za 07:00–20:00 · spoed 24/7.</p>
        </div>
      </aside>
    </div>
  </section>
</Base>
