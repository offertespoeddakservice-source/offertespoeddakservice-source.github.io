---
import "../styles/global.css";
import { SITE, NAV, telHref, waHref } from "../site.config.ts";
import { PLAATSEN } from "../data/plaatsen.ts";

interface Props {
  title: string;
  description: string;
  path?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const { title, description, path = "/", schema, noindex = false } = Astro.props;
const canonical = new URL(path, SITE.url).href;

const businessSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  name: SITE.bedrijfsnaam,
  description: SITE.slogan,
  url: SITE.url,
  telephone: `+${SITE.telefoonE164}`,
  email: SITE.email,
  image: `${SITE.url}/og.png`,
  logo: `${SITE.url}/favicon.svg`,
  priceRange: "€€",
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    opens: "07:00",
    closes: "20:00",
  },
  areaServed: PLAATSEN.map((p) => ({ "@type": "City", name: p.naam })),
  address: { "@type": "PostalAddress", addressLocality: SITE.basisplaats, addressRegion: "Noord-Brabant", addressCountry: "NL" },
  geo: { "@type": "GeoCoordinates", latitude: SITE.geo.lat, longitude: SITE.geo.lon },
};
if (SITE.reviews.aantal > 0) {
  businessSchema.aggregateRating = { "@type": "AggregateRating", ratingValue: SITE.reviews.score, reviewCount: SITE.reviews.aantal };
}
const crumbs = path !== "/" ? path.split("/").filter(Boolean) : [];
const breadcrumbSchema = crumbs.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
        ...crumbs.map((seg, i) => ({
          "@type": "ListItem",
          position: i + 2,
          name: decodeURIComponent(seg).replace(/-/g, " "),
          item: new URL("/" + crumbs.slice(0, i + 1).join("/") + "/", SITE.url).href,
        })),
      ],
    }
  : null;
const websiteSchema = { "@context": "https://schema.org", "@type": "WebSite", name: SITE.bedrijfsnaam, url: SITE.url, inLanguage: "nl-NL" };
const schemas = [businessSchema, websiteSchema, ...(breadcrumbSchema ? [breadcrumbSchema] : []), ...(Array.isArray(schema) ? schema : schema ? [schema] : [])];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />
    <meta name="theme-color" content="#0f2742" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.bedrijfsnaam} />
    <meta property="og:image" content={`${SITE.url}/og.png`} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.bedrijfsnaam} — dakdekker regio Den Bosch`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE.url}/og.png`} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <a href="#hoofd" class="skip">Naar inhoud</a>
    <header class="site-header">
      <div class="wrap">
        <a href="/" class="brand">Spoed <span>Dak</span> Service</a>
        <nav class="nav" aria-label="Hoofdmenu">
          <div class="nav-links">
            {NAV.map((item) => (
              <a href={item.href} aria-current={path === item.href || path.startsWith(item.href + "/") ? "page" : undefined}>{item.label}</a>
            ))}
          </div>
          <a class="btn btn--primary" href={telHref}>Bel {SITE.telefoonWeergave}</a>
        </nav>
        <details class="m-menu">
          <summary aria-label="Menu openen">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0f2742" stroke-width="2.4" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </summary>
          <div class="m-menu-panel">
            {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
            <a class="btn btn--primary" href={telHref}>Bel {SITE.telefoonWeergave}</a>
            <a class="btn btn--wa" href={waHref()}>WhatsApp Rens</a>
          </div>
        </details>
      </div>
    </header>

    {SITE.stormActief && (
      <div class="storm-banner" role="status">
        <div class="wrap">
          Het stormt momenteel in de regio. Daardoor komen er nu meer aanvragen binnen dan normaal — reageren kan iets langer duren, maar je hoort in elk geval binnen 24 uur iets van me. Zie je al schade aan je dak? <a href="/dak-apk">Vraag hier een Dak-APK aan (€49)</a>, dan kijk ik zo snel mogelijk met je mee.
        </div>
      </div>
    )}

    <div class="trust-strip">
      Échte dakdekker uit de buurt — géén callcenter · garantie op het werk
    </div>

    {crumbs.length > 0 && (
      <nav class="breadcrumbs" aria-label="Kruimelpad">
        <div class="wrap">
          <a href="/">Home</a>
          {crumbs.map((seg, i) => (
            <Fragment>
              <span class="sep" aria-hidden="true">›</span>
              {i === crumbs.length - 1 ? (
                <span aria-current="page">{decodeURIComponent(seg).replace(/-/g, " ")}</span>
              ) : (
                <a href={"/" + crumbs.slice(0, i + 1).join("/") + "/"}>{decodeURIComponent(seg).replace(/-/g, " ")}</a>
              )}
            </Fragment>
          ))}
        </div>
      </nav>
    )}

    <main id="hoofd">
      <slot />
    </main>

    <section class="section section--navy cta-band">
      <div class="wrap">
        <p class="eyebrow" style="color:#ffb486;">Direct geholpen</p>
        <h2>Dak nakijken of een lek verhelpen?</h2>
        <p class="lead" style="margin: 0 auto 24px; color:#c2d2e3;">
          Je krijgt mij — Rens — meteen aan de lijn. Twijfel je of je dak nog goed is? Vraag de <strong>Dak-APK</strong> aan: binnen een dagdeel een compleet keuringsrapport met foto's, voor €49.
        </p>
        <div class="btn-row" style="justify-content:center;">
          <a class="btn btn--primary" href={telHref}>Bel {SITE.telefoonWeergave}</a>
          <a class="btn btn--wa" href="/dak-apk">Bekijk de Dak-APK — €49</a>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="wrap">
        <div class="cols">
          <div>
            <h3>{SITE.bedrijfsnaam}</h3>
            <p>{SITE.slogan}</p>
            <p>Werkgebied: {SITE.regioOmschrijving}.</p>
            <p>Ma–za 07:00–20:00 · spoed 24/7</p>
            <p>Bellen of appen: meestal dezelfde dag antwoord.</p>
          </div>
          <div>
            <h3>Diensten</h3>
            <ul>
              <li><a href="/diensten/goten-reinigen">Goten reinigen</a></li>
              <li><a href="/diensten/daklekkage">Daklekkage &amp; spoed</a></li>
              <li><a href="/diensten/dakreparatie">Dakreparatie</a></li>
              <li><a href="/diensten/platte-daken">Platte daken (EPDM)</a></li>
              <li><a href="/diensten/dakgoot-vervangen">Dakgoot vervangen</a></li>
              <li><a href="/diensten/dakcoating">Dak coaten</a></li>
              <li><a href="/diensten/schoorsteen-vegen">Schoorsteen vegen</a></li>
              <li><a href="/diensten/stormschade">Stormschade</a></li>
              <li><a href="/diensten">Alle diensten →</a></li>
            </ul>
          </div>
          <div>
            <h3>Contact</h3>
            <ul>
              <li><a href={telHref}>{SITE.telefoonWeergave}</a></li>
              <li><a href={waHref()}>WhatsApp</a></li>
              <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
              <li><a href="/werkgebied">Werkgebied</a></li>
              <li><a href="/prijzen">Prijzen</a></li>
              <li><a href="/over">Over Rens</a></li>
              <li><a href="/kennisbank">Kennisbank</a></li>
            </ul>
          </div>
        </div>
        <div class="foot-bottom">
          © {new Date().getFullYear()} {SITE.bedrijfsnaam}{SITE.kvk ? ` · KvK ${SITE.kvk}` : ""} · regio {SITE.basisplaats}
        </div>
      </div>
    </footer>

    <div class="sticky-cta">
      <a class="btn btn--primary" href={telHref} aria-label={`Bel ${SITE.telefoonWeergave}`}>Bellen</a>
      <a class="btn btn--wa" href={waHref()} aria-label="WhatsApp Rens">WhatsApp</a>
    </div>
  </body>
</html>
